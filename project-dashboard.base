filters:
  and:
    - file.hasTag("task")
    - file.ext == "md"
formulas:
  days_left: if(due, (date(due) - today()).days, "")
  is_overdue: if(due, date(due) < today() && status != "done", false)
  priority_icon: if(priority == "P0", "🔴", if(priority == "P1", "🟡", "🟢"))
  status_icon: if(status == "done", "✅", if(status == "in-progress", "🔄", if(status == "blocked", "🚫", "⏳")))
  owner_display: if(owner, owner, "미배정")
  day_label: if(day, "D" + day, "")
properties:
  formula.priority_icon:
    displayName: "!"
  formula.days_left:
    displayName: D-Day
  formula.owner_display:
    displayName: 담당
  formula.day_label:
    displayName: Day
  status:
    displayName: 상태
  track:
    displayName: 트랙
  demo_critical:
    displayName: 데모필수
views:
  - type: table
    name: 전체 태스크
    groupBy:
      property: status
      direction: ASC
    order:
      - formula.priority_icon
      - formula.status_icon
      - file.name
      - track
      - formula.owner_display
      - formula.day_label
      - due
      - formula.days_left
      - demo_critical
    summaries:
      formula.days_left: Min
    columnSize:
      formula.priority_icon: 62
      formula.status_icon: 157
      file.name: 131
      note.track: 105
      formula.owner_display: 106
      formula.day_label: 128
      note.due: 120
      formula.days_left: 148
  - type: table
    name: 오늘 할 일
    filters:
      and:
        - status != "done"
        - status != "blocked"
    groupBy:
      property: track
      direction: ASC
    order:
      - formula.priority_icon
      - file.name
      - track
      - formula.owner_display
      - demo_critical
  - type: table
    name: 데모 크리티컬
    filters:
      and:
        - demo_critical == true
        - status != "done"
    order:
      - formula.priority_icon
      - file.name
      - status
      - formula.owner_display
      - formula.days_left
  - type: table
    name: 완료
    filters:
      and:
        - status == "done"
    order:
      - file.name
      - track
      - formula.owner_display
      - due
